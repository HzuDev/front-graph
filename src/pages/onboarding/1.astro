---
import OnboardingStep from '../../components/onboarding/OnboardingStep.astro';
import { Fingerprint, ArrowRight, UserCheck } from 'lucide-react';
import { buildPath } from '../../lib/utils/paths';
---

<OnboardingStep step={1} totalSteps={2} title="Bienvenido" eyebrow="Paso 01">
  <div slot="left-content" class="max-w-md">
    <div
      class="mb-4 inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 backdrop-blur-md"
    >
      <span class="relative flex h-2 w-2">
        <span
          class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#bf4a18] opacity-75"
        ></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-[#bf4a18]"
        ></span>
      </span>
      <span
        class="text-[10px] font-bold uppercase tracking-tighter text-white/90"
        >Acceso Abierto</span
      >
    </div>

    <h1
      class="text-7xl md:text-8xl font-black text-white leading-[0.85] tracking-tighter mb-8 italic text-balance"
    >
      Todo en <br />
      <span
        class="text-transparent bg-clip-text bg-gradient-to-r from-white/40 to-white/10 not-italic"
        >un lugar.</span
      >
    </h1>

    <p
      class="text-white/70 text-lg md:text-xl font-medium leading-snug max-w-[90%]"
    >
      La plataforma ciudadana para auditar el historial de quienes buscan
      representarte.
    </p>
  </div>

  <div slot="left-features" class="mt-12">
    <div
      class="inline-flex items-center gap-4 p-[1px] rounded-3xl bg-gradient-to-r from-[#bf4a18] to-transparent"
    >
      <div
        class="flex items-center gap-3 py-3 px-5 bg-[#0f0a09] rounded-[calc(1.5rem-1px)] backdrop-blur-xl"
      >
        <UserCheck size={18} className="text-[#bf4a18]" />
        <span
          class="text-[11px] font-black uppercase tracking-[0.15em] text-white/90"
          >Información Centralizada</span
        >
      </div>
    </div>
  </div>

  <div
    slot="background-icon"
    class="opacity-[0.03] scale-150 rotate-12 transition-transform duration-1000"
  >
    <Fingerprint size={500} strokeWidth={0.5} className="text-white" />
  </div>

  <div slot="right-content" class="max-w-sm mx-auto flex flex-col gap-6 py-12">
    <div
      class="relative group p-8 rounded-[2.5rem] bg-white border border-[#bf4a18]/5 shadow-2xl shadow-black/5"
    >
      <div
        class="absolute -top-4 -right-2 bg-[#bf4a18] text-white text-[10px] font-black px-3 py-1 rounded-lg rotate-3"
      >
        NUEVO
      </div>
      <h2
        class="text-3xl font-black text-[#bf4a18] tracking-tighter italic leading-none mb-4"
      >
        Mira la trayectoria <br /> de tus candidatos.
      </h2>
      <p class="text-[#120907]/70 text-sm font-medium leading-relaxed">
        Accede a perfiles detallados e historial político de forma sencilla.
        Monitor es un espacio abierto para que consultes antes de decidir.
      </p>
    </div>
  </div>

  <div slot="actions" class="max-w-sm mx-auto w-full group">
    <a
      href={buildPath('/onboarding/2')}
      class="w-full bg-[#bf4a18] text-white p-6 rounded-[2rem] font-black text-xs uppercase tracking-[0.2em] flex items-center justify-between shadow-xl shadow-[#bf4a18]/30 hover:bg-[#d15621] transition-all duration-300 hover:-translate-y-1 active:scale-95"
    >
      <span class="ml-2">CONTINUAR</span>
      <div
        class="bg-white/20 p-2 rounded-full group-hover:bg-white/30 transition-colors"
      >
        <ArrowRight
          size={20}
          className="group-hover:translate-x-1 transition-transform"
        />
      </div>
    </a>
  </div>
</OnboardingStep>
